{
  "name": "@vitaliysimkin/t-components",
  "version": "0.7.1",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vitaliysimkin/t-components.git"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./global": {
      "types": "./dist/globalComponents.d.ts"
    },
    "./style.css": "./dist/index.css"
  },
  "scripts": {
    "prepare": "vite build",
    "build": "vue-tsc --noEmit && vite build",
    "build:nocheck": "vite build",
    "dev": "vite --config playground/vite.config.ts",
    "build:playground": "vite build --config playground/vite.config.ts",
    "typecheck": "vue-tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "check:pack": "publint",
    "check:types": "attw --pack .",
    "check:size": "size-limit",
    "release:patch": "npm version patch && git push --follow-tags",
    "release:minor": "npm version minor && git push --follow-tags",
    "release:major": "npm version major && git push --follow-tags"
  },
  "peerDependencies": {
    "@iconify/vue": ">=4.0.0",
    "@vueuse/core": ">=10.0.0",
    "vue": "^3.5.0",
    "vue-router": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "vue-router": {
      "optional": true
    }
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-vue": "^0.1.3",
    "@codemirror/state": "^6.5.2",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.41.0",
    "@iconify-json/system-uicons": "^1.2.4",
    "@iconify/vue": "^5.0.0",
    "@size-limit/preset-small-lib": "^12.1.0",
    "@testing-library/vue": "^8.1.0",
    "@types/node": "^24.10.1",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.8.1",
    "@vueuse/core": "^14.1.0",
    "codemirror": "^6.0.2",
    "date-fns": "^4.1.0",
    "eslint": "^10.2.1",
    "eslint-plugin-vue": "^10.8.0",
    "happy-dom": "^20.9.0",
    "material-icons": "^1.13.14",
    "publint": "^0.3.18",
    "size-limit": "^12.1.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.58.2",
    "vite": "npm:rolldown-vite@7.2.5",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.4",
    "vue": "^3.5.24",
    "vue-router": "^4.6.4",
    "vue-tsc": "^3.1.4"
  },
  "overrides": {
    "vite": "npm:rolldown-vite@7.2.5"
  }
}
